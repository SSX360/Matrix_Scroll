# Matrix Scroll / Digital Rain — local environment template
# Copy to .env (which is gitignored) and fill in real values locally.
# Real OS environment variables always override values in .env.

# --- LLM backends (optional) ---
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Slack dev-team notifier ---
# Preferred: a single BOT token (xoxb-...) with chat:write, invited to the
# channels below. The notifier posts via chat.postMessage to any of them.
SLACK_BOT_TOKEN=

# Channel routing (defaults shown; override only if you rename channels).
SLACK_CHANNEL_CICD=#feed-ci-cd-qa
SLACK_CHANNEL_CHECKOUT=#feed-web3-checkout
SLACK_CHANNEL_ANNOUNCE=#00-announcements

# Optional per-channel Incoming Webhooks. If set, a webhook takes precedence
# over the bot token for that channel. Leave blank to use the bot token.
SLACK_WEBHOOK_CICD=
SLACK_WEBHOOK_CHECKOUT=
SLACK_WEBHOOK_ANNOUNCE=
